# MCP TravelCode — environment variables
#
# Copy to `.env` and fill the section that matches how you run the server.
# See README.md for an overview of the three modes (A/B/C).
#
# ---------------------------------------------------------------------------
# Common (all modes)
# ---------------------------------------------------------------------------

# TravelCode REST API base URL — leave as-is unless pointing at a staging
# environment.
TRAVELCODE_API_BASE_URL=https://api.travel-code.com/v1

# Async flight-search polling tuning (optional).
# TRAVELCODE_POLL_INTERVAL_MS=2000
# TRAVELCODE_POLL_TIMEOUT_MS=90000

# ---------------------------------------------------------------------------
# Mode B — Local stdio
# ---------------------------------------------------------------------------
# Recommended: run `npx mcp-travelcode-auth auth` once. Tokens are saved to
# ~/.travelcode/tokens.json and refreshed automatically — no env var needed.
#
# Legacy fallback only: set a static Bearer token here. Bypasses OAuth.
# TRAVELCODE_API_TOKEN=your-static-bearer-token

# ---------------------------------------------------------------------------
# Mode C — Self-hosted HTTP server (`npm run start:http`)
# ---------------------------------------------------------------------------
# Tokens are NOT taken from env in this mode — every MCP request brings its
# own per-user Bearer token in the Authorization header. Configure transport
# instead:

# Port the HTTP server listens on.
# PORT=3000

# Public origin of THIS MCP server (no path). Used for OAuth Protected
# Resource Metadata + Authorization Server Metadata. In production set to
# the public HTTPS URL fronting nginx, e.g. https://mcp.your-domain.com
# RESOURCE_URI=http://localhost:3000

# Origin of the upstream OAuth Authorization Server. travel-code.com unless
# you run your own AS that issues the same scopes.
# OAUTH_ISSUER=https://travel-code.com
